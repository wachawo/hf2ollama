# HuggingFace access token (Read scope).
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GGUF output type. One of: f16 (default), f32, bf16, q8_0, auto.
# Anything else is rejected at startup before any download happens.
OUTTYPE=f16

# Where to clone llama.cpp. Default (when unset) is <workspace>/llama.cpp.
# Set to ../llama.cpp to reuse a shared clone one level above this workspace.
HF2OLLAMA_LLAMA_CPP_DIR=./llama.cpp

# llama.cpp ref (branch / tag / 40-char SHA) to clone. Defaults to "master".
# Pin to an audited tag for reproducible conversions, e.g. b4400.
#HF2OLLAMA_LLAMA_CPP_REF=master

# Where `hf2ollama init` creates a venv when no venv is already active.
# Ignored if init is run from inside an existing venv (that one is reused).
# Default (when unset) is <workspace>/venv.
#HF2OLLAMA_VENV=./venv

# Workspace root. Everything below — HF snapshots, caches, llama.cpp clone,
# venv — lives under this dir. Defaults to the current working directory.
#HF2OLLAMA_WORKSPACE=.

# Where to put HF snapshots (and resulting GGUFs). Default: <workspace>/hf.
#HF2OLLAMA_HF_DIR=./hf

# huggingface_hub cache. Default: <workspace>/.hf_cache.
#HF2OLLAMA_CACHE_DIR=./.hf_cache
